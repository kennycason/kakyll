            </div>
            <div class="panel-body">
                <a href="{{this.postUrl}}">
                    <img src="{{this.path}}" alt="{{this.postTitle}}" class="img-responsive">
                </a>
            </div>
        </div>
    </div>
    {{/each}}
</div>
